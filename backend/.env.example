# Database Connection String
# For direct connection use port 5432. For Supabase transaction pooling use port 6543.
# Remember to URL-encode special characters in passwords (e.g., '@' becomes '%40').
DATABASE_URL="postgresql://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>?sslmode=require"

# Alternative local database fallback for isolated unit testing
# DATABASE_URL="sqlite:///./local_test.db"

# Security & Authentication Configurations
# Generate a secure string using: openssl rand -hex 32
JWT_SECRET="your-fallback-super-secret-development-key"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080

# Application Environment Tracking
APP_ENV="development"

# Cross-Origin Resource Sharing (CORS) Configuration
# Defines which frontend domain is permitted to interact with this API
FRONTEND_URL="http://localhost:3000"