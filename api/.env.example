# Backend Environment Variables
# Copy this file to .env and fill in real values from your Supabase project.

# Supabase project URL
# Get from: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase JWT Secret (HS256) - for backward compatibility
# Get from: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Supabase JWK (ES256) - for current token verification
# Get from: Supabase Dashboard → Settings → API → JWT Keys → Current Key → Key Details → Public Key Set
# Format: {"keys":[{"x":"...","y":"...","alg":"ES256","crv":"P-256","ext":true,"kid":"...","kty":"EC","key_ops":["verify"]}]}
SUPABASE_JWK='{"keys":[{"x":"YOUR_X_VALUE","y":"YOUR_Y_VALUE","alg":"ES256","crv":"P-256","ext":true,"kid":"YOUR_KEY_ID","kty":"EC","key_ops":["verify"]}]}'

# Comma-separated list of allowed CORS origins (frontend URLs)
# Local: http://localhost:3000
# Production: Add your Vercel URL
BACKEND_CORS_ORIGINS=http://localhost:3000
